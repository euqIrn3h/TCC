<TelaPrincipal>:
    orientation: "vertical"
    padding: 20
    spacing: 15

    canvas.before:
        Color:
            rgb: 0, 0.05, 0.15, 0.5
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: "Algoritmo Genético para Circuitos Lógicos"
        font_size: 24
        bold: True
        color: 1, 1, 1, 1
        size_hint_y: None
        height: "50dp"

    Button:
        text: "Executar algoritmo"
        size_hint_y: None
        height: "50dp"
        font_size: 18
        bold: True
        background_normal: ""
        background_color: (0.6, 0.6, 0.6, 1) if root.executando else (0.2, 0.5, 0.8, 1)
        color: 1, 1, 1, 1
        disabled: root.executando
        on_press: root.executar()

    BoxLayout:
        orientation: "vertical"
        size_hint_y: None
        height: "60dp"
        spacing: 5

        ProgressBar:
            max: 100
            value: root.progresso

        Label:
            text: root.progresso_texto
            font_size: 16
            color: 1, 1, 1, 1
            size_hint_y: None
            height: "20dp"

    ScrollView:
        do_scroll_x: False

        Label:
            text: root.resultado
            text_size: self.width - 20, None
            size_hint_y: None
            height: self.texture_size[1] + 20
            font_size: 18
            color: 1, 1, 1, 1
            valign: "top"
            halign: "left"
            padding: 10, 10